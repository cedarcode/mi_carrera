<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="mt-5 text-center text-3xl/9 font-bold tracking-tight text-gray-900">Registro</h2>
  </div>
  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm space-y-4">
    <%= form_with(model: resource, url: registration_path(resource_name), class: "space-y-4", local: true) do |f| %>
      <div>
        <%= f.label :email, "Correo electrónico", class: "block text-sm/6 font-medium text-gray-900" %>
        <%= f.email_field :email, class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6", required: true, autofocus: true %>
      </div>

      <div>
        <%= render 'shared/password_field', f:, resource:, field: :password, label_text: "Nueva contraseña", autocomplete: "new-password", required: true, with_forgot_password_link: false %>
      </div>
      <div>
        <%= render 'shared/password_field', f:, resource:, field: :password_confirmation, label_text: "Confirma tu nueva contraseña", autocomplete: "new-password", required: true, with_forgot_password_link: false %>
      </div>

      <div>
        <%= f.button "Registrarse", class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>
      </div>
    <% end %>
    <p class="text-center text-sm/6 text-gray-500 mt-2">
      ¿Ya estás registrado?
      <%= link_to 'Ingresar', new_session_path(resource), class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
  <%= render 'devise/shared/google_sign_in' %>
</div>
