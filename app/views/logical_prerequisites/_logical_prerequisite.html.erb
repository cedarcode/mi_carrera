<% if logical_prerequisite.logical_operator == "not" %>
  <%= render logical_prerequisite.operands_prerequisites, negative: true %>
<% else %>
  <div data-controller="collapsible" >
    <a data-action="click->collapsible#toggle" class="flex items-center py-3 px-4 hover:bg-gray-100 cursor-pointer">
      <%= material_icon "chevron_right", data: { collapsible_target: "button" } %>

      <span class="flex-1"><%= logical_prerequisite_description(logical_prerequisite, negative) %></span>

      <%= render 'prerequisites/met_checkmark', prerequisite: logical_prerequisite, negative: %>
    </a>

    <div class="hidden ml-5" data-collapsible-target="collapsible" >
      <%= render logical_prerequisite.operands_prerequisites, negative: false %>
    </div>
  </div>
<% end %>
